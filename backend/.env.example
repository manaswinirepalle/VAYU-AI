# Backend Environment Variables (copy to .env and fill in your values)
# CPCB API Configuration
CPCB_API_URL=https://api.data.gov.in/resource/3b01bcb8-0b14-4abf-b6f2-c1bfd384ba69
CPCB_API_KEY=your_cpcb_api_key_here

# OpenWeather API (optional, for weather forecast)
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Data directory (optional, defaults to ./backend/data)
# DATA_DIR=/path/to/data
